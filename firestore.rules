rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function adminDoc() { return get(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function activeAdmin() { return signedIn() && adminDoc().data.active == true; }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /{collection}/{document=**} {
      allow read: if collection in ['artists','albums','songs','videoAlbums','videos','products','productVariants','newsArticles','sitePages','siteSettings']
                  && resource.data.status == 'published';
      allow read, write: if activeAdmin();
    }

    match /orders/{orderId} {
      allow read, write: if activeAdmin();
    }

    match /customers/{customerId} {
      allow read, write: if activeAdmin();
    }

    match /downloads/{downloadId} {
      allow read, write: if activeAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if activeAdmin();
    }
  }
}