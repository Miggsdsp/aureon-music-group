rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function pluralAdminExists() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function singularAdminExists() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/admin/$(request.auth.uid));
    }

    function pluralAdminActive() {
      return pluralAdminExists()
        && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    function singularAdminActive() {
      return singularAdminExists()
        && firestore.get(/databases/(default)/documents/admin/$(request.auth.uid)).data.active == true;
    }

    function activeAdmin() {
      return pluralAdminActive() || singularAdminActive();
    }

    function validImage() {
      return request.resource != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function validAudio() {
      return request.resource != null
        && request.resource.size < 150 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    function validVideo() {
      return request.resource != null
        && request.resource.size < 750 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    function validDocument() {
      return request.resource != null
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('text/.*'));
    }

    match /public/videos/thumbnails/{allPaths=**} {
      allow read: if true;
      allow create, update: if activeAdmin() && validImage();
      allow delete: if activeAdmin();
    }

    match /public/videos/files/{allPaths=**} {
      allow read: if true;
      allow create, update: if activeAdmin() && validVideo();
      allow delete: if activeAdmin();
    }

    match /public/{path=**} {
      allow read: if true;
      allow create, update: if activeAdmin()
        && (validImage() || validAudio() || validVideo() || validDocument());
      allow delete: if activeAdmin();
    }

    match /private/full-tracks/{allPaths=**} {
      allow read: if activeAdmin();
      allow create, update: if activeAdmin() && validAudio();
      allow delete: if activeAdmin();
    }

    match /private/{allPaths=**} {
      allow read: if activeAdmin();
      allow create, update: if activeAdmin()
        && (validImage() || validAudio() || validVideo() || validDocument());
      allow delete: if activeAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
